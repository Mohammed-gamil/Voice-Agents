LIVEKIT_URL=<your LiveKit server URL>
LIVEKIT_API_KEY=<your API Key>
LIVEKIT_API_SECRET=<your API Secret>
LIVEKIT_AGENT_NAME=tenant-voice-agent
TENANT_ID=acme_corp

# Required when using direct provider plugins or OpenAI Realtime S2S.
OPENAI_API_KEY=<your OpenAI API Key>
DEEPGRAM_API_KEY=<your Deepgram API Key>
CARTESIA_API_KEY=<your Cartesia API Key>

# Optional generic service integrations used by custom actions.
TICKETING_WEBHOOK_URL=https://tickets.example.com/api/tickets
TICKETING_API_TOKEN=<ticketing bearer token>
CRM_WEBHOOK_URL=https://crm.example.com/api/records
CRM_API_TOKEN=<crm bearer token>
SMTP_HOST=smtp.example.com
SMTP_USERNAME=<smtp username>
SMTP_PASSWORD=<smtp password>
SMTP_FROM_EMAIL=assistant@example.com

# PostgreSQL database for durable tenant state.
DATABASE_DSN=postgresql://voice_agent:change_me@localhost:5432/voice_agents

# Optional UI hardening. Required when UI_HOST is not localhost.
UI_HOST=127.0.0.1
UI_PORT=8765
UI_ALLOW_REMOTE=false
UI_AUTH_TOKEN=<set before remote exposure>
